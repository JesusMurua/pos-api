{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "POS.API",
    "Audience": "POS.Frontend",
    "OwnerExpirationDays": 30,
    "PinExpirationHours": 12
  },
  "Cors": {
    "Origins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "https://restaurant-app-roan-two.vercel.app"
    ]
  },
  "AllowedHosts": "*"
}
